{"blogs":[{"title":"Proof of Concept: Database Restore Arbitrary Collection Overwrite","slug":"poc-restore-overwrite","status":"published","author":"Security Audit Team","category":"SECURITY","date":"JULY 09, 2026","desc":"This is a security proof of concept showing database modification via path traversal backup restore.","longContent":"We successfully uploaded a custom JSON file disguised as a PNG and restored the database from it. This shows arbitrary database overwrite is possible.","readTime":"1 MIN READ","sort_order":0}]}